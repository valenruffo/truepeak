# True Peak AI — Environment Variables
# Copy this file to .env and fill in the values

# JWT secret for label owner authentication (use a strong random string)
JWT_SECRET=

# OpenAI API key for AI-powered analysis
OPENAI_API_KEY=

# Resend API key for email notifications
RESEND_API_KEY=

# Directory for database and uploaded files (defaults to ./data)
DATA_DIR=./data
