# True Peak AI — Environment Variables
# Copy this file to .env and fill in the values

# JWT secret for label owner authentication (use a strong random string)
JWT_SECRET=your-secret-key-here

# OpenRouter API key for LLM-powered email generation
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Resend API key for email notifications
RESEND_API_KEY=re_xxx

# Directory for database and uploaded files (defaults to ./data)
DATA_DIR=./data

# Polar webhook secret (from Polar > Settings > Webhooks > your webhook > Secret)
POLAR_WEBHOOK_SECRET=whsec_xxx
